{
  "name": "nsg-ui",
  "version": "0.0.1",
  "description": "Not-So-Good UI - A SolidJS component library with Tailwind CSS",
  "type": "module",
  "main": "./dist/index/index.js",
  "module": "./dist/index/index.js",
  "types": "./dist/index/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index/index.d.ts",
      "solid": "./dist/index/index.jsx",
      "import": "./dist/index/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "solid": "./dist/icons/index.jsx",
      "import": "./dist/icons/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@kobalte/core": "^0.13.11",
    "solid-js": "^1.9.13"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.1"
  },
  "devDependencies": {
    "@kobalte/core": "0.13.11",
    "solid-js": "1.9.13",
    "tsup": "8.3.5",
    "tsup-preset-solid": "2.2.0",
    "typescript": "6.0.3"
  },
  "keywords": [
    "solid",
    "solidjs",
    "ui",
    "components",
    "tailwind",
    "kobalte"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nxtcoder17/nsg-ui"
  },
  "bugs": {
    "url": "https://github.com/nxtcoder17/nsg-ui/issues"
  },
  "homepage": "https://github.com/nxtcoder17/nsg-ui#readme"
}
